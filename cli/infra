# ─── Router ───────────────────────────────────────────────────────────────────

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    bootstrap)            cmd_bootstrap "$@" ;;
    init)                 cmd_init "$@" ;;
    plan)                 cmd_plan "$@" ;;
    apply)                cmd_apply "$@" ;;
    destroy)              cmd_destroy "$@" ;;
    validate)             cmd_validate ;;
