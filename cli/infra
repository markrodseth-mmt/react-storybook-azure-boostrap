#!/usr/bin/env bash
# =============================================================================
#  infra  — Quadient Azure Infrastructure CLI
# =============================================================================
#  Usage:  ./cli/infra <command> [options]
#
#  Commands
#  --------
#  bootstrap   <env>              Provision remote Terraform state backend
#  init        <env>              Initialise Terraform for an environment
#  plan        <env>              Show Terraform plan
#  apply       <env>              Apply Terraform plan
#  destroy     <env>              Destroy environment (with confirmation)
#  validate                       Validate all Terraform configs
#  fmt                            Format all Terraform files
#  output      <env> [key]        Show Terraform outputs
#
#  login       <env>              Authenticate to Azure + ACR
#  whoami                         Show current Azure identity
#
#  acr:build   <env> <image> <path>  Build & push image to ACR
#  acr:list    <env>              List all images in ACR
#  acr:purge   <env> <image>      Remove untagged image manifests
#
#  afd:purge   <env> [path]       Purge Azure Front Door CDN cache
#  afd:origins <env>              Show Front Door origin health
#  afd:legacy  <env> [action]    Manage legacy site origin (status|enable|disable)
#
#  app:restart <env> <app>        Restart an App Service (nginx|frontend|backend)
#  app:logs    <env> <app>        Stream live logs from an App Service
#  app:shell   <env> <app>        Open SSH into an App Service container
#
#  func:invoke <env> <func-name>  Invoke a function manually
#  func:logs   <env>              Stream function app logs
#
#  secrets:set <env>              Interactive: set Storyblok secrets in App Settings
#  secrets:rotate-redis <env>    Rotate Redis access key and update App Settings
#
#  state:list  <env>              List all resources in Terraform state
#  state:import <env> <addr> <id> Import an existing Azure resource into state
#  state:rm    <env> <addr>       Remove a resource from state (no destroy)
#
#  cost        <env>              Estimate monthly cost via Infracost
#  docs                           Open architecture docs in browser
# =============================================================================

set -euo pipefail

# ─── Colour helpers ───────────────────────────────────────────────────────────
RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

info()    { echo -e "${CYAN}[info]${RESET}  $*"; }
success() { echo -e "${GREEN}[ok]${RESET}    $*"; }
warn()    { echo -e "${YELLOW}[warn]${RESET}  $*"; }
error()   { echo -e "${RED}[error]${RESET} $*" >&2; }
die()     { error "$*"; exit 1; }
header()  { echo -e "\n${BOLD}${CYAN}══ $* ══${RESET}\n"; }

# ─── Paths ────────────────────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"
TF_DIR="$ROOT_DIR/terraform"

# ─── Dependency checks ────────────────────────────────────────────────────────
require() {
  for cmd in "$@"; do
    command -v "$cmd" &>/dev/null || die "'$cmd' is required but not installed."
  done
}

# ─── Environment helpers ──────────────────────────────────────────────────────
valid_env() {
  [[ "$1" =~ ^(dev|staging|prod)$ ]] || die "Invalid environment '$1'. Must be dev, staging, or prod."
}

env_vars_file() {
  echo "$TF_DIR/environments/$1/terraform.tfvars"
}

backend_file() {
  echo "$TF_DIR/environments/$1/backend.hcl"
}

# Reads a value from terraform output
tf_output() {
  local env=$1 key=$2
  cd "$TF_DIR"
  terraform output -raw "$key" 2>/dev/null || echo ""
}

# Resolves ACR login server from terraform output or falls back to state
acr_login_server() {
  local env=$1
  tf_output "$env" "container_registry_login_server" 2>/dev/null \
    || die "Could not resolve ACR login server. Run: infra output $env container_registry_login_server"
}

# Resolves the subscription ID from the environment tfvars file
subscription_for_env() {
  local env=$1
  local tfvars
  tfvars="$(env_vars_file "$env")"
  grep -oP 'subscription_id\s*=\s*"\K[^"]+' "$tfvars" 2>/dev/null || echo ""
}

# Resolves App Service name by role
app_name_for() {
  local env=$1 role=$2
  local prefix="quadient-${env}"
  case "$role" in
    nginx)    az webapp list --resource-group "rg-${prefix}-main" --query "[?contains(name,'nginx')].name" -o tsv 2>/dev/null | head -1 ;;
    frontend) az webapp list --resource-group "rg-${prefix}-main" --query "[?contains(name,'frontend')].name" -o tsv 2>/dev/null | head -1 ;;
    backend)  az webapp list --resource-group "rg-${prefix}-main" --query "[?contains(name,'backend')].name" -o tsv 2>/dev/null | head -1 ;;
    *)        die "Unknown app role '$role'. Use: nginx | frontend | backend" ;;
  esac
}

resource_group() {
  echo "rg-quadient-$1-main"
}

# ─── Commands ─────────────────────────────────────────────────────────────────

cmd_bootstrap() {
  local env="${1:-}" sub="${2:-}"
  [[ -z "$env" ]] && die "Usage: infra bootstrap <env> [subscription-id]"
  valid_env "$env"
  require az

  header "Bootstrapping Terraform state backend"

  local rg="rg-quadient-tfstate"
  local sa="stquadienttfstate"
  local container="tfstate"
  local location="uksouth"

  [[ -n "$sub" ]] && az account set --subscription "$sub" && info "Switched to subscription: $sub"

  info "Creating resource group: $rg"
  az group create --name "$rg" --location "$location" --output none \
    && success "Resource group ready"

  info "Creating storage account: $sa (GRS + soft delete)"
  az storage account create \
    --name "$sa" \
    --resource-group "$rg" \
    --location "$location" \
    --sku Standard_GRS \
    --min-tls-version TLS1_2 \
    --allow-blob-public-access false \
    --output none && success "Storage account ready"

  info "Enabling versioning for state history"
  az storage account blob-service-properties update \
    --account-name "$sa" \
    --resource-group "$rg" \
    --enable-versioning true \
    --enable-delete-retention true \
    --delete-retention-days 30 \
    --output none

  info "Creating blob container: $container"
  az storage container create \
    --name "$container" \
    --account-name "$sa" \
    --auth-mode login \
    --output none && success "Container ready"

  info "Adding resource lock to prevent accidental deletion"
  az lock create \
    --name "DoNotDelete-tfstate" \
    --resource-group "$rg" \
    --lock-type CanNotDelete \
    --notes "Protects Terraform state backend" \
    --output none && success "Resource lock applied"

  success "Bootstrap complete. Backend config: $(backend_file "$env")"
  info "Next step: infra init $env"
}

cmd_init() {
  local env="${1:-}"
  [[ -z "$env" ]] && die "Usage: infra init <env>"
  valid_env "$env"
  require terraform

  local backend
  backend="$(backend_file "$env")"
  [[ -f "$backend" ]] || die "Backend file not found: $backend"

  header "Initialising Terraform — $env"
  cd "$TF_DIR"
  terraform init \
    -backend-config="$backend" \
    -reconfigure
  success "Init complete"
}

cmd_plan() {
  local env="${1:-}"
  [[ -z "$env" ]] && die "Usage: infra plan <env>"
  valid_env "$env"
  require terraform

  local tfvars
  tfvars="$(env_vars_file "$env")"
  [[ -f "$tfvars" ]] || die "tfvars not found: $tfvars"

  header "Planning Terraform — $env"
  cd "$TF_DIR"
  terraform plan \
    -var-file="$tfvars" \
    -out="${env}.tfplan" \
    -compact-warnings
}

cmd_apply() {
  local env="${1:-}"
  [[ -z "$env" ]] && die "Usage: infra apply <env>"
  valid_env "$env"
  require terraform

  local plan_file="$TF_DIR/${env}.tfplan"

  if [[ -f "$plan_file" ]]; then
    info "Applying saved plan: ${env}.tfplan"
    cd "$TF_DIR"
    terraform apply "$plan_file"
  else
    warn "No saved plan found — running plan + apply"
    local tfvars
    tfvars="$(env_vars_file "$env")"
    cd "$TF_DIR"
    terraform apply -var-file="$tfvars" -compact-warnings
  fi

  success "Apply complete"
  cmd_output "$env"
}

cmd_destroy() {
  local env="${1:-}"
  [[ -z "$env" ]] && die "Usage: infra destroy <env>"
  valid_env "$env"
  require terraform

  warn "You are about to DESTROY all resources in environment: ${BOLD}$env${RESET}"
  read -rp "Type the environment name to confirm: " confirm
  [[ "$confirm" == "$env" ]] || die "Confirmation mismatch. Aborting."

  local tfvars
  tfvars="$(env_vars_file "$env")"
  cd "$TF_DIR"
  terraform destroy -var-file="$tfvars"
}

cmd_validate() {
  require terraform
  header "Validating Terraform configs"
  cd "$TF_DIR"
  terraform fmt -check -recursive && success "Formatting OK"
  terraform validate && success "Validation OK"
}

cmd_fmt() {
  require terraform
  header "Formatting Terraform files"
  cd "$TF_DIR"
  terraform fmt -recursive
  success "Done"
}

cmd_output() {
  local env="${1:-}" key="${2:-}"
  [[ -z "$env" ]] && die "Usage: infra output <env> [key]"
  valid_env "$env"
  require terraform

  cd "$TF_DIR"
  if [[ -n "$key" ]]; then
    terraform output -raw "$key"
  else
    header "Outputs — $env"
    terraform output
  fi
}

# ─── Auth ─────────────────────────────────────────────────────────────────────

cmd_login() {
  local env="${1:-}"
  [[ -z "$env" ]] && die "Usage: infra login <env>"
  valid_env "$env"
  require az

  header "Authenticating — $env"
  az login --output none
  success "Azure login complete"

  local acr
  acr="$(acr_login_server "$env")" || { warn "Skipping ACR login (infra not yet deployed)"; return 0; }
  info "Logging into ACR: $acr"
  az acr login --name "${acr%%.*}"
  success "ACR login complete"
}

cmd_whoami() {
  require az
  header "Current Azure identity"
  az account show --query "{Subscription:id,Tenant:tenantId,User:user.name}" -o table
}

# ─── ACR ──────────────────────────────────────────────────────────────────────

cmd_acr_build() {
  local env="${1:-}" image="${2:-}" context="${3:-.}"
  [[ -z "$env" || -z "$image" ]] && die "Usage: infra acr:build <env> <image[:tag]> [context-path]"
  valid_env "$env"
  require az

  local acr
  acr="$(acr_login_server "$env")"
  local acr_name="${acr%%.*}"

  header "Building remotely via ACR Tasks — ${acr}/${image}"
  az acr build \
    --registry "$acr_name" \
    --image "$image" \
    "$context"
  success "Pushed: ${acr}/${image}"
}

cmd_acr_list() {
  local env="${1:-}"
  [[ -z "$env" ]] && die "Usage: infra acr:list <env>"
  valid_env "$env"
  require az

  local acr
  acr="$(acr_login_server "$env")"
  local acr_name="${acr%%.*}"

  header "Images in ACR — $acr_name"
  az acr repository list --name "$acr_name" -o table
}

cmd_acr_purge() {
  local env="${1:-}" image="${2:-}"
  [[ -z "$env" || -z "$image" ]] && die "Usage: infra acr:purge <env> <image>"
  valid_env "$env"
  require az

  local acr
  acr="$(acr_login_server "$env")"
  local acr_name="${acr%%.*}"

  header "Purging untagged manifests — $image"
  az acr run \
    --registry "$acr_name" \
    --cmd "acr purge --filter '${image}:.*' --untagged --ago 7d" \
    /dev/null
  success "Purge complete"
}

# ─── Front Door ───────────────────────────────────────────────────────────────

cmd_afd_purge() {
  local env="${1:-}" path="${2:-/}"
  [[ -z "$env" ]] && die "Usage: infra afd:purge <env> [path]"
  valid_env "$env"
  require az

  local rg profile
  rg="$(resource_group "$env")"
  profile="afd-quadient-${env}"

  header "Purging AFD CDN cache — $path"
  az afd endpoint purge \
    --resource-group "$rg" \
    --profile-name "$profile" \
    --endpoint-name "fde-quadient-${env}" \
    --content-paths "$path" \
    --output none
  success "Cache purged"
}

cmd_afd_origins() {
  local env="${1:-}"
  [[ -z "$env" ]] && die "Usage: infra afd:origins <env>"
  valid_env "$env"
  require az

  local rg="$(resource_group "$env")" profile="afd-quadient-${env}"
  header "Front Door origin health — $env"
  az afd origin-group list \
    --resource-group "$rg" \
    --profile-name "$profile" \
    --query "[].{OriginGroup:name,Sessions:sessionAffinityState}" \
    -o table
}

cmd_afd_legacy() {
  local env="${1:-}" action="${2:-status}"
  [[ -z "$env" ]] && die "Usage: infra afd:legacy <env> [status|enable|disable]"
  valid_env "$env"
  require az

  local rg="$(resource_group "$env")" profile="afd-quadient-${env}"

  case "$action" in
    status)
      header "Legacy origin status — $env"
      az afd origin show \
        --resource-group "$rg" \
        --profile-name "$profile" \
        --origin-group-name "og-legacy" \
        --origin-name "origin-legacy" \
        --query "{Name:name,HostName:hostName,Enabled:enabledState}" \
        -o table 2>/dev/null || warn "No legacy origin configured"
      ;;
    enable)
      info "Enabling legacy origin"
      az afd origin update \
        --resource-group "$rg" \
        --profile-name "$profile" \
        --origin-group-name "og-legacy" \
        --origin-name "origin-legacy" \
        --enabled-state Enabled \
        --output none
      success "Legacy origin enabled"
      ;;
    disable)
      info "Disabling legacy origin"
      az afd origin update \
        --resource-group "$rg" \
        --profile-name "$profile" \
        --origin-group-name "og-legacy" \
        --origin-name "origin-legacy" \
        --enabled-state Disabled \
        --output none
      success "Legacy origin disabled"
      ;;
    *) die "Unknown action: $action. Use: status | enable | disable" ;;
  esac
}

# ─── App Service ──────────────────────────────────────────────────────────────

cmd_app_restart() {
  local env="${1:-}" role="${2:-}"
  [[ -z "$env" || -z "$role" ]] && die "Usage: infra app:restart <env> <nginx|frontend|backend>"
  valid_env "$env"
  require az

  local rg app
  rg="$(resource_group "$env")"
  app="$(app_name_for "$env" "$role")"
  [[ -z "$app" ]] && die "Could not resolve app name for role: $role"

  header "Restarting $role ($app)"
  az webapp restart --resource-group "$rg" --name "$app"
  success "Restarted: $app"
}

cmd_app_logs() {
  local env="${1:-}" role="${2:-}"
  [[ -z "$env" || -z "$role" ]] && die "Usage: infra app:logs <env> <nginx|frontend|backend>"
  valid_env "$env"
  require az

  local rg app
  rg="$(resource_group "$env")"
  app="$(app_name_for "$env" "$role")"

  header "Streaming logs — $app"
  az webapp log tail --resource-group "$rg" --name "$app"
}

cmd_app_shell() {
  local env="${1:-}" role="${2:-}"
  [[ -z "$env" || -z "$role" ]] && die "Usage: infra app:shell <env> <nginx|frontend|backend>"
  valid_env "$env"
  require az

  local rg app
  rg="$(resource_group "$env")"
  app="$(app_name_for "$env" "$role")"

  header "Opening SSH — $app"
  az webapp ssh --resource-group "$rg" --name "$app"
}

# ─── Function App ─────────────────────────────────────────────────────────────

cmd_func_invoke() {
  local env="${1:-}" func_name="${2:-}"
  [[ -z "$env" || -z "$func_name" ]] && die "Usage: infra func:invoke <env> <function-name>"
  valid_env "$env"
  require az

  local rg="$(resource_group "$env")"
  local func_app
  func_app="$(az functionapp list --resource-group "$rg" --query "[0].name" -o tsv)"
  [[ -z "$func_app" ]] && die "No function app found in resource group: $rg"

  info "Fetching master key for $func_app"
  local master_key
  master_key="$(az functionapp keys list --resource-group "$rg" --name "$func_app" --query "masterKey" -o tsv)"
  [[ -z "$master_key" ]] && die "Could not retrieve master key for $func_app"

  header "Invoking function: $func_name"
  az rest \
    --method post \
    --url "https://${func_app}.azurewebsites.net/admin/functions/${func_name}" \
    --headers "Content-Type=application/json" "x-functions-key=${master_key}" \
    --body "{}"
}

cmd_func_logs() {
  local env="${1:-}"
  [[ -z "$env" ]] && die "Usage: infra func:logs <env>"
  valid_env "$env"
  require az

  local rg="$(resource_group "$env")"
  local func_app
  func_app="$(az functionapp list --resource-group "$rg" --query "[0].name" -o tsv)"

  header "Streaming function logs — $func_app"
  az webapp log tail --resource-group "$rg" --name "$func_app"
}

# ─── Secrets ──────────────────────────────────────────────────────────────────

cmd_secrets_set() {
  local env="${1:-}"
  [[ -z "$env" ]] && die "Usage: infra secrets:set <env>"
  valid_env "$env"
  require az

  header "Setting Storyblok secrets — $env"

  local rg="$(resource_group "$env")"
  local frontend_app
  frontend_app="$(app_name_for "$env" "frontend")"

  read -rsp "Storyblok API Token: " sb_token; echo

  info "Updating app settings on $frontend_app"
  az webapp config appsettings set \
    --resource-group "$rg" \
    --name "$frontend_app" \
    --settings \
      "STORYBLOK_TOKEN=${sb_token}" \
    --output none

  success "Secrets updated. App will restart to pick up changes."
}

cmd_secrets_rotate_redis() {
  local env="${1:-}"
  [[ -z "$env" ]] && die "Usage: infra secrets:rotate-redis <env>"
  valid_env "$env"
  require az

  header "Rotating Redis key — $env"

  local rg="$(resource_group "$env")"
  local redis_name
  redis_name="$(az redis list --resource-group "$rg" --query "[0].name" -o tsv)"

  info "Regenerating Redis primary key"
  az redis regenerate-keys \
    --resource-group "$rg" \
    --name "$redis_name" \
    --key-type Primary \
    --output none

  local new_key
  new_key="$(az redis list-keys --resource-group "$rg" --name "$redis_name" --query "primaryKey" -o tsv)"
  local conn_str="${redis_name}.redis.cache.windows.net:6380,password=${new_key},ssl=True,abortConnect=False"

  info "Updating Key Vault secret"
  local kv_name
  kv_name="$(az keyvault list --resource-group "$rg" --query "[0].name" -o tsv)"
  if [[ -n "$kv_name" ]]; then
    az keyvault secret set \
      --vault-name "$kv_name" \
      --name "redis-connection-string" \
      --value "$conn_str" \
      --output none && success "Key Vault secret updated"
  else
    warn "Key Vault not found in $rg — skipping KV update"
  fi

  info "Updating connection strings on backend and function app"
  local backend_app func_app
  backend_app="$(app_name_for "$env" "backend")"
  func_app="$(az functionapp list --resource-group "$rg" --query "[0].name" -o tsv)"

  az webapp config connection-string set \
    --resource-group "$rg" --name "$backend_app" \
    --connection-string-type Custom \
    --settings "RedisConnectionString=${conn_str}" \
    --output none

  az functionapp config appsettings set \
    --resource-group "$rg" --name "$func_app" \
    --settings "REDIS_CONNECTION_STRING=${conn_str}" \
    --output none

  success "Redis key rotated and connection strings updated."
}

# ─── Terraform State ──────────────────────────────────────────────────────────

cmd_state_list() {
  local env="${1:-}"
  [[ -z "$env" ]] && die "Usage: infra state:list <env>"
  valid_env "$env"
  require terraform
  cd "$TF_DIR"
  terraform state list
}

cmd_state_import() {
  local env="${1:-}" addr="${2:-}" id="${3:-}"
  [[ -z "$env" || -z "$addr" || -z "$id" ]] && die "Usage: infra state:import <env> <resource-addr> <azure-resource-id>"
  valid_env "$env"
  require terraform
  local tfvars; tfvars="$(env_vars_file "$env")"
  cd "$TF_DIR"
  terraform import -var-file="$tfvars" "$addr" "$id"
}

cmd_state_rm() {
  local env="${1:-}" addr="${2:-}"
  [[ -z "$env" || -z "$addr" ]] && die "Usage: infra state:rm <env> <resource-addr>"
  valid_env "$env"
  require terraform
  warn "Removing from state (resource will NOT be destroyed): $addr"
  read -rp "Confirm? [y/N] " confirm
  [[ "$confirm" =~ ^[Yy]$ ]] || die "Aborted"
  cd "$TF_DIR"
  terraform state rm "$addr"
}

# ─── Cost estimate ────────────────────────────────────────────────────────────

cmd_cost() {
  local env="${1:-}"
  [[ -z "$env" ]] && die "Usage: infra cost <env>"
  valid_env "$env"
  require infracost

  header "Cost estimate — $env"
  local tfvars; tfvars="$(env_vars_file "$env")"
  cd "$TF_DIR"
  infracost breakdown \
    --path . \
    --terraform-var-file "$tfvars" \
    --format table
}

# ─── Docs ─────────────────────────────────────────────────────────────────────

cmd_docs() {
  local url="https://learn.microsoft.com/en-us/azure/frontdoor/"
  info "Opening docs: $url"
  if command -v xdg-open &>/dev/null; then
    xdg-open "$url"
  elif command -v open &>/dev/null; then
    open "$url"
  else
    echo "$url"
  fi
}

