---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page not found">
  <section class="not-found">
    <h1>404</h1>
    <p>Page not found.</p>
    <a href="/">Go home</a>
  </section>
</Layout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    gap: 1rem;
  }
  .not-found h1 {
    font-size: 4rem;
    font-weight: 800;
    color: #ccc;
  }
  .not-found a {
    color: #2563eb;
  }
</style>
