---
interface Props {
  title?: string;
}

const { title = "Bootstrap" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href="/" class="logo">Bootstrap</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} Bootstrap. All rights reserved.</p>
    </footer>
    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        font-family: system-ui, -apple-system, sans-serif;
        line-height: 1.6;
        color: #1a1a1a;
      }
      .site-header {
        padding: 1rem 2rem;
        border-bottom: 1px solid #e5e5e5;
      }
      .logo {
        font-weight: 700;
        font-size: 1.25rem;
        text-decoration: none;
        color: #1a1a1a;
      }
      main {
        min-height: 80vh;
      }
      .site-footer {
        padding: 2rem;
        text-align: center;
        border-top: 1px solid #e5e5e5;
        color: #666;
        font-size: 0.875rem;
      }
    </style>
  </body>
</html>
