---
import { storyblokEditable } from "@storyblok/astro";

const { blok } = Astro.props;
---

<figure class="sb-image" {...storyblokEditable(blok)}>
  {
    blok.image?.filename && (
      <img
        src={`${blok.image.filename}/m/1200x0`}
        alt={blok.image.alt ?? ""}
        loading="lazy"
      />
    )
  }
  {blok.caption && <figcaption>{blok.caption}</figcaption>}
</figure>

<style>
  .sb-image {
    max-width: 720px;
    margin: 2rem auto;
    padding: 0 2rem;
  }
  .sb-image img {
    width: 100%;
    height: auto;
    border-radius: 8px;
  }
  .sb-image figcaption {
    margin-top: 0.5rem;
    text-align: center;
    font-size: 0.875rem;
    color: #666;
  }
</style>
